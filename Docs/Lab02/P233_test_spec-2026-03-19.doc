	<li>preț: double &amp;&amp; preț &gt; 0 &amp;&amp; preț = p.preț</li>
	<li>categorie: string &amp;&amp; categorie = p.categorie</li>
	<li>tip: string &amp;&amp; tip = p.tip</li>
</ul>
</td></tr><tr><td width="20%" valign="top"><span class="label">Execution type:</span></td><td colspan="3">Manual</td></tr>
